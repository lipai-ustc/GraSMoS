{
  "system": {
    "name": "MoS2",
    "task": "global_search"
  },
  "potential": {
    "type": "deepmd",
    "model": "M2C.pb"
  },
  "monte_carlo": {
    "steps": 1000,
    "temperature": 500
  },
  "climbing": {
    "random_direction": {
      "mode": ["thermo","atomic"],
      "ratio": [[[0.05,0.95],0.5],[[0.1,0.9],0.5]],
      "rotation_param": 1,
      "AE_factor": 2
    },
    "gaussian":{
      "height": 0.5,
      "Nmax": 20
    },
    "displace": {
      "average_dr": 0.1,
      "max_dr": 0.2
    }
  },
  "optimizer": {
    "max_steps": 100,
    "fmax": 0.05
  },
  "mobile_control": {
    "mode": "all"
  },
  "output": {
    "directory": "cosmos_output",
    "rd_xyz": true,
    "debug": false
  }
}

